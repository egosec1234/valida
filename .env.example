# Frontend (Vite) - these are bundled into the client and are not secret.
# Supabase's anon key is designed to be public; access control is enforced by RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only (Vercel Routing Middleware) - deliberately NOT prefixed with
# VITE_, so it is never bundled into the client JavaScript. Set this in the
# Vercel dashboard, not in a committed file.
GATE_PASSWORD=

# The Anthropic API key is NOT a frontend/Vercel environment variable.
# It only ever exists as a Supabase Edge Function secret:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
